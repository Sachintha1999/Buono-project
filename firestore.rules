rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ═══════════════════════════════════════
    // ⚙️ BUONO PHASE 2: ACADEMY & SETTINGS ⭐
    // ═══════════════════════════════════════
    match /settings/{document=**} {
      allow read, write: if true;
    }
    match /students/{document=**} {
      allow read, write: if true;
    }
    match /courses/{document=**} {
      allow read, write: if true;
    }
    match /leads/{document=**} {
      allow read, write: if true;
    }
    
    // ⭐ Call Center Events & Comments Collections
    match /events/{document=**} {
      allow read, write: if true;
    }
    match /callCenterComments/{document=**} {
      allow read, write: if true;
    }

    // ═══════════════════════════════════════
    // 🆔 ATOMIC COUNTERS (v12.4) ⭐
    // For Student ID + Receipt No generation
    // ═══════════════════════════════════════
    match /counters/{document=**} {
      allow read, write: if true;
    }

    // ═══════════════════════════════════════
    // 👥 USER & AUTH
    // ═══════════════════════════════════════
    match /employees/{document=**} {
      allow read, write: if true;
    }
    
    // ═══════════════════════════════════════
    // 💰 CASHIER / DAY END
    // ═══════════════════════════════════════
    match /dayEndReports/{document=**} {
      allow read, write: if true;
    }
    
    // ═══════════════════════════════════════
    // 📦 INVENTORY
    // ═══════════════════════════════════════
    match /inventoryItems/{document=**} {
      allow read, write: if true;
    }
    match /inventoryCategories/{document=**} {
      allow read, write: if true;
    }
    match /stockMovements/{document=**} {
      allow read, write: if true;
    }
    match /stockCounts/{document=**} {
      allow read, write: if true;
    }
    match /stockIssues/{document=**} {
      allow read, write: if true;
    }
    
    // ═══════════════════════════════════════
    // 🍳 KITCHEN
    // ═══════════════════════════════════════
    match /recipes/{document=**} {
      allow read, write: if true;
    }
    match /staffMeals/{document=**} {
      allow read, write: if true;
    }
    match /wastage/{document=**} {
      allow read, write: if true;
    }
    match /kitchenOrders/{document=**} {
      allow read, write: if true;
    }
    
    // ═══════════════════════════════════════
    // 🛒 PURCHASING
    // ═══════════════════════════════════════
    match /purchases/{document=**} {
      allow read, write: if true;
    }
    match /suppliers/{document=**} {
      allow read, write: if true;
    }
    match /purchaseReturns/{document=**} {
      allow read, write: if true;
    }
    match /supplierCreditNotes/{document=**} {
      allow read, write: if true;
    }
    
    // ═══════════════════════════════════════
    // 📊 REPORTS & ANALYTICS
    // ═══════════════════════════════════════
    match /salesReports/{document=**} {
      allow read, write: if true;
    }
    match /plLossRecords/{document=**} {
      allow read, write: if true;
    }
    match /auditLogs/{document=**} {
      allow read, write: if true;
    }
    
    // ═══════════════════════════════════════
    // 🔮 FUTURE COLLECTIONS (POS, etc.)
    // ═══════════════════════════════════════
    match /orders/{document=**} {
      allow read, write: if true;
    }
    match /menu/{document=**} {
      allow read, write: if true;
    }
    match /stock/{document=**} {
      allow read, write: if true;
    }
    match /payments/{document=**} {
      allow read, write: if true;
    }
    match /transfers/{document=**} {
      allow read, write: if true;
    }
    
    // ═══════════════════════════════════════
    // 🔒 FALLBACK (Deny everything else)
    // ═══════════════════════════════════════
    match /{document=**} {
      allow read, write: if false; 
    }
    
  }
}